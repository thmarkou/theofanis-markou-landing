# =========================================================================
# Environment variables for Theofanis Markou landing.
# Copy this file to `.env` and fill in values for your local environment.
# In production, every variable except the Forge/OWNER block is required.
# =========================================================================

# ---- Runtime ------------------------------------------------------------
NODE_ENV=development
PORT=3000

# ---- Session signing (ALWAYS required, any env) -------------------------
# Must be at least 32 characters. Generate with:
#   openssl rand -base64 48
JWT_SECRET=replace-me-with-a-long-random-string-at-least-32-chars

# ---- Manus OAuth (required in production) -------------------------------
VITE_APP_ID=
OAUTH_SERVER_URL=

# ---- Database (required in production, used for user & contact tables) --
# Example: mysql://user:password@localhost:3306/theofanis_landing
DATABASE_URL=

# ---- Manus Forge storage proxy (optional) -------------------------------
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ---- Admin identification (optional) ------------------------------------
# When a user logs in whose openId matches this value, they are granted the
# "admin" role automatically.
OWNER_OPEN_ID=

# ---- Client-side only (Vite picks these up automatically) --------------
# Analytics endpoint + website id consumed by client/index.html.
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
VITE_OAUTH_PORTAL_URL=
